{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/hvac", "destination": "/hvac/index.html" },
    { "source": "/roofing", "destination": "/roofing/index.html" },
    { "source": "/plumbing", "destination": "/plumbing/index.html" },
    { "source": "/electrical", "destination": "/electrical/index.html" },
    { "source": "/insurance", "destination": "/insurance/index.html" },
    { "source": "/real-estate", "destination": "/real-estate/index.html" },
    { "source": "/legal", "destination": "/legal/index.html" },
    { "source": "/medical", "destination": "/medical/index.html" },
    { "source": "/locksmith", "destination": "/locksmith/index.html" },
    { "source": "/property-mgmt", "destination": "/property-mgmt/index.html" },
    { "source": "/home-services", "destination": "/home-services/index.html" },
    { "source": "/custom", "destination": "/custom/index.html" },
    { "source": "/auto", "destination": "/locksmith/index.html" },
    { "source": "/voice", "destination": "/voice/index.html" },
    { "source": "/pricing", "destination": "/pricing/index.html" },
    { "source": "/compare", "destination": "/compare/index.html" },
    { "source": "/speedlead", "destination": "/speedlead/index.html" },
    { "source": "/calculator", "destination": "/calculator/index.html" },
    { "source": "/hge", "destination": "/hge/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), autoplay=(self), geolocation=(), interest-cohort=()" }
      ]
    }
  ]
}
